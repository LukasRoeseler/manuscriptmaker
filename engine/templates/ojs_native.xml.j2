{#- OJS Native XML import package (targets OJS 3.3 / 3.4 schema).
    Generated by engine/scripts/build_ojs.py. Galley files are embedded as
    base64 so the whole article (metadata + PDF + HTML + JATS) imports from a
    single file via Tools -> Import/Export -> Native XML Plugin.
    Adjust `section-ref` / `user-group-ref` in themes/<name>/theme.yml to match
    your OJS instance's section and user-group labels. -#}
<?xml version="1.0" encoding="UTF-8"?>
<articles xmlns="http://pkp.sfu.ca/SWORD"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://pkp.sfu.ca/SWORD native.xsd">
  <article xmlns="http://pkp.sfu.ca/SWORD" locale="{{ locale }}"
           date_submitted="{{ date_published }}" status="3"
           submission_progress="" current_publication_id="1" stage="production">
    <id type="internal" advice="ignore">1</id>
    {% for g in galleys %}
    <submission_file xmlns="http://pkp.sfu.ca/SWORD" id="{{ g.file_id }}"
                     created_at="{{ date_published }}" updated_at="{{ date_published }}"
                     file_id="{{ g.file_id }}" stage="proof" viewable="true"
                     genre="{{ g.genre }}" uploader="{{ uploader }}"
                     filetype="{{ g.mimetype }}">
      <name locale="{{ locale }}">{{ g.filename }}</name>
      <file id="{{ g.file_id }}" filesize="{{ g.filesize }}" extension="{{ g.extension }}">
        <embed encoding="base64">{{ g.b64 }}</embed>
      </file>
    </submission_file>
    {% endfor %}
    <publication xmlns="http://pkp.sfu.ca/SWORD" locale="{{ locale }}" version="1"
                 status="3" primary_contact_id="1" url_path="" seq="0"
                 date_published="{{ date_published }}" section_ref="{{ section_ref }}"
                 access_status="0">
      <id type="internal" advice="ignore">1</id>
      {% if doi %}<id type="doi" advice="update">{{ doi }}</id>{% endif %}
      <title locale="{{ locale }}">{{ title }}</title>
      {% if abstract %}<abstract locale="{{ locale }}">{{ abstract }}</abstract>{% endif %}
      {% if license_url %}<licenseUrl>{{ license_url }}</licenseUrl>{% endif %}
      <copyrightHolder locale="{{ locale }}">{{ authors[0].family if authors else journal }}</copyrightHolder>
      <copyrightYear>{{ year }}</copyrightYear>
      <authors xmlns="http://pkp.sfu.ca/SWORD">
        {% for a in authors %}
        <author include_in_browse="true" user_group_ref="{{ user_group_ref }}"
                seq="{{ loop.index0 }}" id="{{ loop.index }}"
                {% if a.corresponding %}primary_contact="true"{% endif %}>
          <givenname locale="{{ locale }}">{{ a.given }}</givenname>
          {% if a.family %}<familyname locale="{{ locale }}">{{ a.family }}</familyname>{% endif %}
          {% if a.affiliations %}<affiliation locale="{{ locale }}">{{ a.affiliations[0].name }}</affiliation>{% endif %}
          <email>{{ a.email or fallback_email }}</email>
          {% if a.orcid %}<orcid>https://orcid.org/{{ a.orcid }}</orcid>{% endif %}
        </author>
        {% endfor %}
      </authors>
      {% for g in galleys %}
      <article_galley xmlns="http://pkp.sfu.ca/SWORD" locale="{{ locale }}" approved="false">
        <id type="internal" advice="ignore">{{ g.file_id }}</id>
        <name locale="{{ locale }}">{{ g.label }}</name>
        <seq>{{ loop.index0 }}</seq>
        <submission_file_ref id="{{ g.file_id }}"/>
      </article_galley>
      {% endfor %}
      {% if keywords %}
      <keywords locale="{{ locale }}">
        {% for k in keywords %}<keyword>{{ k }}</keyword>{% endfor %}
      </keywords>
      {% endif %}
    </publication>
  </article>
</articles>
